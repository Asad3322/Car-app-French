{
  "css.validate": false,
  "scss.validate": false,
  "less.validate": false,

  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",

  "files.associations": {
    "*.css": "tailwindcss"
  },

  "tailwindCSS.includeLanguages": {
    "plaintext": "html",
    "typescript": "html",
    "typescriptreact": "html"
  }
}